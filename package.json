{
  "name": "schemafy",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "build:frontend": "cd apps/frontend && pnpm run build",
    "build:backend": "./gradlew :core:build :api:build",
    "infra": "podman compose up -d mariadb redis || true",
    "dev": "pnpm run infra && turbo run dev --parallel",
    "dev:frontend": "cd apps/frontend && pnpm run dev",
    "dev:backend": "cd apps/backend && pnpm run dev",
    "infra:up": "podman compose up -d mariadb redis",
    "infra:down": "podman compose down",
    "lint": "turbo run lint",
    "format": "turbo run format",
    "format:check": "turbo run format:check",
    "test": "turbo run test",
    "docs": "./gradlew :api:asciidoctor && open apps/backend/api/build/docs/asciidoc/api-guide.html",
    "docs:build": "./gradlew :api:asciidoctor",
    "docs:open": "open apps/backend/api/build/docs/asciidoc/api-guide.html"
  },
  "devDependencies": {
    "turbo": "^2.5.6"
  },
  "engines": {
    "node": ">=18"
  },
  "packageManager": "pnpm@10.33.0",
  "pnpm": {
    "onlyBuiltDependencies": [
      "@nestjs/core",
      "esbuild"
    ]
  }
}
